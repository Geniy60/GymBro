{
  "expo": {
    "name": "GymBro",
    "owner": "geniy60",
    "slug": "gymbro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-arms.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon-arms.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDE5B2"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.evgeniy.gymbro",
      "permissions": [
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM"
      ],
      "versionCode": 5,
      "adaptiveIcon": {
        "backgroundColor": "#FDE5B2",
        "foregroundImage": "./assets/android-icon-foreground-arms.png",
        "backgroundImage": "./assets/android-icon-background-arms.png",
        "monochromeImage": "./assets/android-icon-monochrome-arms.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon-arms.png"
    },
    "plugins": [
      "expo-font",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "0ea9c50c-1bca-409d-8b72-e43529475e2b"
      }
    }
  }
}
